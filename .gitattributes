# Auto detect text files and normalize to LF
* text=auto

# Force important text files
*.c3proj text eol=lf
*.json text eol=lf

# Binary files (no diff/merge)
*.c3p binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.webm binary
*.mp3 binary
*.wav binary
*.ogg binary
*.ttf binary
*.otf binary
*.psd binary