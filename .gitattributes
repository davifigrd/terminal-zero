# =========================================
# Normalize text files automatically
# =========================================
* text=auto

# =========================================
# Construct 3 project files
# =========================================
*.c3proj text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# =========================================
# Source/code files
# =========================================
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# SVG is text-based
*.svg text eol=lf

# =========================================
# Binary assets (disable diff/merge)
# =========================================
*.c3p binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.bmp binary
*.ico binary

# Audio
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary

# Video
*.mp4 binary
*.webm binary
*.mov binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Adobe / design files
*.psd binary
*.aseprite binary

# Archives
*.zip binary
*.rar binary
*.7z binary

# Executables
*.exe binary
*.dll binary